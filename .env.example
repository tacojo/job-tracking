# Copy to .env in the project root (same folder as docker-compose.yml)
# Database (SQLite by default) - stored in ./storage (persists across restarts)
DATABASE_URL=sqlite:///./storage/db/job_tracking.db

# Local file storage base path - stored in ./storage (persists across restarts)
STORAGE_PATH=./storage

# Application documents (optional). Default: STORAGE_PATH/files — same as Docker.
# FILES_ROOT=./storage/files

# Local testing: bypass Google auth (BYPASS_AUTH=true)
BYPASS_AUTH=true

# Google OAuth (required for sign-in production)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:8000/api/v1/auth/callback to Authorised redirect URIs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT secret (change in production)
JWT_SECRET=change-me-in-production

# URLs (for OAuth redirect_uri and frontend redirect)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Optional: OpenAI API key for AI tailoring (Phase 3)
OPENAI_API_KEY=sk-...
