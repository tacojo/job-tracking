# Copy to .env in the project root (same folder as docker-compose.yml)

# --- Database ---
# Local default (Docker / dev):
DATABASE_URL=sqlite:///./storage/db/job_tracking.db
# For migration scripts only (Supabase direct connection, port 5432, sslmode=require):
# DATABASE_URL_POSTGRES=postgresql+psycopg2://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres?sslmode=require

# --- File storage ---
STORAGE_PATH=./storage
# FILES_ROOT defaults to STORAGE_PATH/files
# local = disk under STORAGE_PATH (default for Docker dev)
# supabase = Supabase Storage bucket (Render production)
STORAGE_BACKEND=local
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=job-tracker-files

# --- Auth ---
BYPASS_AUTH=true
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
JWT_SECRET=change-me-in-production

# --- URLs (OAuth redirect + CORS) ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Frontend (Render static site build only) ---
# VITE_API_URL=https://your-api.onrender.com

# --- Per-user OpenAI keys (Settings → AI settings); server encryption:
# SECRETS_ENCRYPTION_KEY=
