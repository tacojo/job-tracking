# Copy to backend/.env when running uvicorn from backend/ (same variables as root .env.example)

# --- Database ---
DATABASE_URL=sqlite:///./storage/db/job_tracking.db
# DATABASE_URL_POSTGRES=postgresql+psycopg2://...

# --- File storage ---
STORAGE_PATH=./storage
STORAGE_BACKEND=local
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=job-tracker-files

# --- Auth ---
BYPASS_AUTH=true
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
JWT_SECRET=change-me-in-production

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Per-user OpenAI keys (Settings → AI settings); server encryption:
# SECRETS_ENCRYPTION_KEY=
